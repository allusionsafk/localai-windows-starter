# localai stack secrets/config -- TEMPLATE.
# Copy this file to ".env" and fill in real values. The real .env is gitignored
# and must never be committed.

# SearXNG signing key. Generate a long random string, e.g. in PowerShell:
#   -join ((48..57)+(65..90)+(97..122) | Get-Random -Count 48 | ForEach-Object {[char]$_})
SEARXNG_SECRET=

# Optional: Cherry Studio local API key for New-CherryLocalClaudeAgent.ps1 and
# the Cherry smoke tests. Prefer a user environment variable for daily use.
CHERRY_STUDIO_API_KEY=
